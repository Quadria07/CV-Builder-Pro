# Environment Variables
# Copy this file to .env and fill in your values

# Groq API key (get one free at https://console.groq.com/keys)
GROQ_API_KEY=

# CORS allowed origins (comma-separated, for local dev server)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Express dev server port
PORT=3001

# Frontend API URL (used by Vite in local dev, leave empty for Vercel deployment)
VITE_API_URL=http://localhost:3001
